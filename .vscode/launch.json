{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch",
      "program": "${workspaceFolder}/src/index.ts",
      "outFiles": ["${workspaceFolder}/dst/**/*.js"],
      "preLaunchTask": "tsc: build - tsconfig.json",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std",
      "env": {
        "DEBUG": "moneyman:*",
        "MONEYMAN_CONFIG_PATH": "/home/gus/development/moneyman/config.json"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Config to single line",
      "program": "${workspaceFolder}/src/scripts/config-to-single-line.ts",
      "outFiles": ["${workspaceFolder}/dst/**/*.js"],
      "preLaunchTask": "tsc: build - tsconfig.json",
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std",
      "cwd": "${workspaceFolder}"
    }
  ]
}
